# ============================================================
# CHANGAYEES — Environment Variables (template)
# Copy to `.env` and fill in. Never commit real secrets.
# Grouped by subsystem (see CHANGAYEES_FINAL_TECHNICAL_ARCHITECTURE.md).
# ============================================================

# --- Core ---------------------------------------------------
NODE_ENV=development
# Public base URL of the app (used for canonical URLs, OG, tracking links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (PostgreSQL + Prisma) -------------------------
# Pooled connection used by the app at runtime
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/changayees?schema=public
# Direct (unpooled) connection used by Prisma migrations
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/changayees?schema=public

# --- Seed (super admin bootstrap) ---------------------------
SUPER_ADMIN_NAME="Changayees Admin"
SUPER_ADMIN_EMAIL=admin@changayees.com
SUPER_ADMIN_PASSWORD=ChangeMe!2026

# --- Auth (admin RBAC) --------------------------------------
JWT_ACCESS_SECRET=replace-with-strong-random-secret
JWT_REFRESH_SECRET=replace-with-strong-random-secret
JWT_ACCESS_TTL=900            # seconds (15m)
JWT_REFRESH_TTL=2592000       # seconds (30d)
PASSWORD_RESET_TTL=3600       # seconds (1h)

# --- Redis (queue + cache + rate limit) ---------------------
# Used by the separate worker (BullMQ) and by API rate limiting.
REDIS_URL=redis://localhost:6379

# --- Object storage (Cloudflare R2 — S3-compatible) ---------
# R2 endpoint: https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=changayees-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public read base — R2 public dev URL (https://pub-xxxx.r2.dev) or a custom domain/CDN
MEDIA_PUBLIC_BASE_URL=

# --- WhatsApp (Meta Cloud API) ------------------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Approved utility template carrying the dynamic body as {{1}} (default per-trigger name)
WHATSAPP_TEMPLATE=order_update
WHATSAPP_TEMPLATE_LANG=en

# --- Cron / internal endpoints ------------------------------
# Vercel Cron sends `Authorization: Bearer <CRON_SECRET>`. Required in production.
CRON_SECRET=replace-with-strong-random-secret

# --- Email (transactional: password reset, invites) ---------
EMAIL_PROVIDER=ses
EMAIL_FROM="Changayees <no-reply@changayees.com>"
EMAIL_API_KEY=

# --- Observability ------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=
NEXT_PUBLIC_GA_ID=

# --- Public contact / WhatsApp deep link --------------------
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_CONTACT_PHONE=
